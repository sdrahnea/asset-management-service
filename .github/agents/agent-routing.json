    },
    {
      "matchAny": ["ux architecture", "interaction model"],
      "agent": "design-ux-architect.md"
    },
    {
      "matchAny": ["ui design", "design system", "visual consistency"],
      "agent": "design-ui-designer.md"
    },
    {
      "matchAny": ["ux research", "usability testing"],
      "agent": "design-ux-researcher.md"
    },
    {
      "matchAny": ["brand", "visual identity"],
      "agent": "design-brand-guardian.md"
    },
    {
      "matchAny": ["sales engineering", "technical demo"],
      "agent": "sales-engineer.md"
    },
    {
      "matchAny": ["deal strategy", "meddpicc"],
      "agent": "sales-deal-strategist.md"
    }
  ]

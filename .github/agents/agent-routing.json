{
  "version": "2026-04-17",
  "defaultAgent": "engineering-senior-developer.md",
  "fallbackOrder": [
    "engineering-codebase-onboarding-engineer.md",
    "engineering-backend-architect.md",
    "engineering-senior-developer.md",
    "engineering-code-reviewer.md"
  ],
  "routes": [
    {
      "matchAny": ["understand codebase", "onboarding", "trace code path", "analyze existing code"],
      "agent": "engineering-codebase-onboarding-engineer.md"
    },
    {
      "matchAny": ["architecture", "service boundaries", "domain design", "refactor design", "system design"],
      "agent": "engineering-backend-architect.md"
    },
    {
      "matchAny": ["ddd", "bounded context", "architectural decision", "technical strategy"],
      "agent": "engineering-software-architect.md"
    },
    {
      "matchAny": ["implement feature", "build crud", "controller service repository", "thymeleaf page"],
      "agent": "engineering-senior-developer.md"
    },
    {
      "matchAny": ["small fix", "minimal diff", "hotfix", "regression patch"],
      "agent": "engineering-minimal-change-engineer.md"
    },
    {
      "matchAny": ["code review", "review pr", "find bugs", "security risks", "performance risks"],
      "agent": "engineering-code-reviewer.md"
    },
    {
      "matchAny": ["slow query", "index", "hibernate performance", "database tuning"],
      "agent": "engineering-database-optimizer.md"
    },
    {
      "matchAny": ["security", "threat model", "vulnerability", "hardening", "secure upload"],
      "agent": "engineering-security-engineer.md"
    },
    {
      "matchAny": ["ci/cd", "pipeline", "automation", "deployment workflow"],
      "agent": "engineering-devops-automator.md"
    },
    {
      "matchAny": ["incident", "outage", "postmortem", "slo", "observability", "reliability"],
      "agent": "engineering-sre.md"
    },
    {
      "matchAny": ["readme", "documentation", "release notes", "developer guide"],
      "agent": "engineering-technical-writer.md"
    },
    {
      "matchAny": ["git workflow", "rebase", "branch strategy", "conventional commits"],
      "agent": "engineering-git-workflow-master.md"
    },
    {
      "matchAny": ["prototype", "poc", "mvp spike"],
      "agent": "engineering-rapid-prototyper.md"
    },
    {
      "matchAny": ["frontend", "react", "vue", "angular", "ui performance"],
      "agent": "engineering-frontend-developer.md"
    },
    {
      "matchAny": ["mobile", "ios", "android", "react native", "flutter"],
      "agent": "engineering-mobile-app-builder.md"
    },
    {
      "matchAny": ["ai feature", "ml model", "inference pipeline"],
      "agent": "engineering-ai-engineer.md"
    },
    {
      "matchAny": ["etl", "elt", "data pipeline", "analytics data"],

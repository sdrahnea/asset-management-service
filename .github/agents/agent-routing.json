    },
    {
      "matchAny": ["data remediation", "self-healing data", "data anomaly fix"],
      "agent": "engineering-ai-data-remediation-engineer.md"
    },
    {
      "matchAny": ["optimization governance", "cost guardrail", "api shadow test"],
      "agent": "engineering-autonomous-optimization-architect.md"
    },
    {
      "matchAny": ["incident command", "war room", "incident coordination"],
      "agent": "engineering-incident-response-commander.md"
    },
    {
      "matchAny": ["siem", "detection rule", "mitre attack", "threat hunting"],
      "agent": "engineering-threat-detection-engineer.md"
    },
    {
      "matchAny": ["email parsing", "email intelligence", "extract from email"],
      "agent": "engineering-email-intelligence-engineer.md"
    },
    {
      "matchAny": ["speech to text", "transcription", "whisper", "diarization"],
      "agent": "engineering-voice-ai-integration-engineer.md"
    },
    {
      "matchAny": ["wordpress", "drupal", "cms"],
      "agent": "engineering-cms-developer.md"
    },
    {
      "matchAny": ["filament", "php admin"],
      "agent": "engineering-filament-optimization-specialist.md"
    },
    {
      "matchAny": ["feishu", "lark", "bitable"],
      "agent": "engineering-feishu-integration-developer.md"
    },
    {
      "matchAny": ["wechat", "mini program"],
      "agent": "engineering-wechat-mini-program-developer.md"
    },
    {
      "matchAny": ["solidity", "smart contract", "evm", "defi"],
      "agent": "engineering-solidity-smart-contract-engineer.md"
    },
    {
      "matchAny": ["firmware", "rtos", "stm32", "esp32", "embedded"],
      "agent": "engineering-embedded-firmware-engineer.md"
    },
    {
      "matchAny": ["product strategy", "roadmap", "feature prioritization"],
      "agent": "product-manager.md"
    },
    {
      "matchAny": ["sprint planning", "prioritize backlog", "sprint scope"],
      "agent": "product-sprint-prioritizer.md"
    },
    {
      "matchAny": ["synthesize feedback", "user feedback", "voice of customer"],
      "agent": "product-feedback-synthesizer.md"
    },
    {
      "matchAny": ["trend analysis", "market research", "competitive research"],
      "agent": "product-trend-researcher.md"
    },
    {
      "matchAny": ["project plan", "convert spec to tasks", "execution plan"],
      "agent": "project-manager-senior.md"
    },
    {
      "matchAny": ["jira workflow", "traceability", "release governance"],
